def solve_backtracking(vertex,
                       graph,
                       m,
                       color,
                       V):

	if vertex == V:
		return True

	for c in range(1, m + 1):

		if is_safe(
			vertex,
			graph,
			color,
			c,
			V
		):
			color[vertex] = c
			if solve_backtracking(
					vertex + 1,
					graph,
					m,
					color,
					V
				):

					return True
                             
			color[vertex] = 0

		return False


